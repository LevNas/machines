-- chezmoi 生成ファイル (source は search_roots.lua.tmpl)。
-- snacks picker の追加横断検索ルートをマシンローカル設定 (chezmoi data) から注入する。
-- 値が空なら空テーブルを返し、消費側は cwd 由来の generic 検索だけにフォールバックする。
local roots = {}
{{- if .nvimSearchRoot }}
local root = {{ .nvimSearchRoot | quote }}
if vim.fn.isdirectory(root) == 1 then
  table.insert(roots, root)
  -- ナレッジエントリは root から導出 (パスは設定値1箇所に集約)
  local entries = root .. "/.claude/knowledge/entries"
  if vim.fn.isdirectory(entries) == 1 then
    table.insert(roots, entries)
  end
end
{{- end }}
return roots
