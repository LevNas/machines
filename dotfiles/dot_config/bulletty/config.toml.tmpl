{{- /* bulletty (TUI RSS リーダー) 設定。
     datapath: 既定の XDG data 位置（マシンごとの home を展開）。
     hooks.after_tui: TUI 終了時に Read Later（お気に入り）記事を個人ナレッジ repo へ同期する。
       rss-fav-sync（dot_local/bin の汎用スクリプト）にアーカイブ先を引数で渡す。
       upstream の hook は sh -c 実行なので引数付きコマンドで問題ない（zsh ラッパーも同様）。
       knowledgeRepo 未設定マシンでは hooks 節ごと省略する。
     注意: bulletty 自身がこのファイルを書き換えることがある（`bulletty dirs library` 等）。
       chezmoi apply で管理状態に戻る（このテンプレートが正）。 */ -}}
datapath = "{{ .chezmoi.homeDir }}/.local/share/bulletty"
{{- if .knowledgeRepo }}

[hooks]
after_tui = "{{ .chezmoi.homeDir }}/.local/bin/rss-fav-sync {{ .chezmoi.homeDir }}/src/github.com/LevNas/{{ .knowledgeRepo }}/bookmarks/rss"
{{- end }}
