# Claude Code: session-specific files (not managed by chezmoi)
.claude/projects/
.claude/memory/
.claude/plans/
.claude/credentials.json
.claude/statsig/
.claude/settings.local.json
.claude/plugins/

# machineType gating: home 専用ツールの設定は home 以外には配布しない。
# .chezmoiignore は chezmoi が常に template 処理する。パターンは target パス基準。
{{ if ne .machineType "home" }}
.config/mise/conf.d/home.toml
{{ end }}

# machineType gating: 個人愛用ツール（work / home 共通）は project マシンに配布しない。
{{ if eq .machineType "project" }}
.config/mise/conf.d/personal.toml
.config/bulletty/**
{{ end }}

# knowledgeRepo gating: 個人ナレッジ repo のパスを注入する env 定義は、
# knowledgeRepo 未設定（= repo が無い）マシンには配布しない。
# （bkm / rss-fav-sync 本体は汎用スクリプトなので全マシン配布。env 不在時は
#   引数必須のエラーメッセージで案内される）
{{ if not .knowledgeRepo }}
.config/zsh/knowledge-dirs.zsh
{{ end }}

# wezterm ランタイム状態 (透過率 opacity.state / フォントサイズ fontsize.state 等を永続化。chezmoi 管理対象外)
.config/wezterm/*.state

# nvim: lazy.nvim のロックファイル (ランタイム書込)。再現性追跡したくなったら管理対象に戻す。
.config/nvim/lazy-lock.json
